# Port the frontend is exposed on (default: 80)
# Change this to run on a different port, e.g. 8080 for Raspberry Pi or non-root setups
APP_PORT=80

# Backend authentication settings
ANYHABIT_SECRET_KEY=change-me-in-production
ANYHABIT_BOOTSTRAP_USERNAME=owner
ANYHABIT_BOOTSTRAP_EMAIL=owner@anyhabit.local
ANYHABIT_BOOTSTRAP_PASSWORD=anyhabit

# Optional backend URL for direct frontend development
VITE_API_URL=
